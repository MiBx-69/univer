{% comment %}
Shop by Category Section
Version: Starter Production Template
Place in: sections/shop-by-category.liquid

NOTE:
This file is intentionally self-contained (Liquid + CSS + JS).
Replace placeholder markup/images as desired.
{% endcomment %}

<section id="shop-by-category-{{ section.id }}" class="shop-category">
  <div class="page-width">
    <div class="shop-category__header">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <a class="view-all" href="{{ section.settings.view_all_url }}">
        {{ section.settings.view_all_text }}
      </a>
    </div>

    <div class="shop-category__track" id="track-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}
        <a class="category-card" href="{{ collection.url }}" {{ block.shopify_attributes }}>
          {% if collection.featured_image %}
            {{
              collection.featured_image
              | image_url: width: 900
              | image_tag:
                loading: 'lazy',
                class: 'category-card__image'
            }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'category-card__image placeholder' }}
          {% endif %}

          <div class="overlay"></div>

          <div class="content">
            <h3>{{ collection.title }}</h3>
            <span>SHOP COLLECTION →</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>

<style>
.shop-category{
padding:90px 0;
background:{{ section.settings.bg }};
}
.shop-category .page-width{max-width:1400px;margin:auto;padding:0 24px;}
.shop-category__header{
display:flex;
justify-content:space-between;
align-items:end;
margin-bottom:32px;
}
.eyebrow{
letter-spacing:.25em;
text-transform:uppercase;
font-size:12px;
color:#c8102e;
margin:0 0 10px;
}
.shop-category h2{
font-size:44px;
font-weight:500;
margin:0;
}
.view-all{
text-decoration:none;
color:#111;
border-bottom:1px solid currentColor;
padding-bottom:4px;
}
.shop-category__track{
display:flex;
gap:24px;
overflow:auto;
scroll-snap-type:x mandatory;
scrollbar-width:none;
}
.shop-category__track::-webkit-scrollbar{display:none;}
.category-card{
position:relative;
flex:0 0 320px;
height:500px;
border-radius:24px;
overflow:hidden;
text-decoration:none;
scroll-snap-align:start;
}
.category-card__image{
width:100%;
height:100%;
object-fit:cover;
transition:.5s ease;
}
.category-card:hover .category-card__image{
transform:scale(1.08);
}
.overlay{
position:absolute;
inset:0;
background:linear-gradient(to top,rgba(0,0,0,.65),rgba(0,0,0,.05));
}
.content{
position:absolute;
left:24px;
right:24px;
bottom:24px;
color:#fff;
z-index:2;
}
.content h3{
margin:0 0 8px;
font-size:34px;
}
.content span{
font-size:12px;
letter-spacing:.18em;
}
@media(max-width:749px){
.shop-category{padding:64px 0;}
.shop-category h2{font-size:34px;}
.category-card{
flex:0 0 82%;
height:420px;
}
}
</style>

<script>
document.addEventListener('DOMContentLoaded',()=>{
 const track=document.getElementById('track-{{ section.id }}');
 if(track){
   let down=false,startX,scrollLeft;
   track.addEventListener('mousedown',e=>{
      down=true;
      startX=e.pageX-track.offsetLeft;
      scrollLeft=track.scrollLeft;
   });
   window.addEventListener('mouseup',()=>down=false);
   track.addEventListener('mouseleave',()=>down=false);
   track.addEventListener('mousemove',e=>{
      if(!down) return;
      e.preventDefault();
      const x=e.pageX-track.offsetLeft;
      track.scrollLeft=scrollLeft-(x-startX);
   });
 }
});
</script>

{% schema %}
{
  "name":"Shop by Category",
  "settings":[
    {
      "type":"text",
      "id":"eyebrow",
      "label":"Eyebrow",
      "default":"CURATED EDITS"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Shop by Category"
    },
    {
      "type":"text",
      "id":"view_all_text",
      "label":"View All Text",
      "default":"VIEW ALL"
    },
    {
      "type":"url",
      "id":"view_all_url",
      "label":"View All URL"
    },
    {
      "type":"color",
      "id":"bg",
      "label":"Background",
      "default":"#ffffff"
    }
  ],
  "blocks":[
    {
      "type":"collection",
      "name":"Collection",
      "settings":[
        {
          "type":"collection",
          "id":"collection",
          "label":"Collection"
        }
      ]
    }
  ],
  "max_blocks":12,
  "presets":[
    {
      "name":"Shop by Category",
      "blocks":[
        {"type":"collection"},
        {"type":"collection"},
        {"type":"collection"},
        {"type":"collection"}
      ]
    }
  ]
}
{% endschema %}
