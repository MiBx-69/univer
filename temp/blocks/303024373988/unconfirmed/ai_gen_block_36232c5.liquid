{% doc %}
  @prompt
    Create a luxury animated marquee announcement bar section for a premium fashion/streetwear brand. It should display scrolling text (e.g. "FREE SHIPPING ON ORDERS OVER ₹5000 · NEW ARRIVALS EVERY FRIDAY · MEMBERS GET EARLY ACCESS") in an infinite horizontal loop. Style: dark background (near-black), gold/champagne colored text, uppercase letter-spacing, minimal and editorial. Should be customizable with editable text, scroll speed, and background/text color settings. Smooth CSS animation, no JavaScript dependencies if possible.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    position: relative;
  }

  .ai-marquee-announcement-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-marquee-announcement-track-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    will-change: transform;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-marquee-announcement-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.item_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    line-height: 1.2;
  }

  .ai-marquee-announcement-separator-{{ ai_gen_id }} {
    display: inline-block;
    margin: 0 {{ block.settings.separator_spacing }}px;
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-marquee-announcement-track-{{ ai_gen_id }} {
      animation: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-announcement-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }

    .ai-marquee-announcement-separator-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-marquee-announcement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-announcement-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-announcement-track-{{ ai_gen_id }}">
      {% for i in (1..2) %}
        {% if block.settings.announcement_text_1 != blank %}
          <span class="ai-marquee-announcement-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_1 }}
          </span>
          <span class="ai-marquee-announcement-separator-{{ ai_gen_id }}">
            {{ block.settings.separator }}
          </span>
        {% endif %}

        {% if block.settings.announcement_text_2 != blank %}
          <span class="ai-marquee-announcement-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_2 }}
          </span>
          <span class="ai-marquee-announcement-separator-{{ ai_gen_id }}">
            {{ block.settings.separator }}
          </span>
        {% endif %}

        {% if block.settings.announcement_text_3 != blank %}
          <span class="ai-marquee-announcement-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_3 }}
          </span>
          <span class="ai-marquee-announcement-separator-{{ ai_gen_id }}">
            {{ block.settings.separator }}
          </span>
        {% endif %}

        {% if block.settings.announcement_text_4 != blank %}
          <span class="ai-marquee-announcement-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_4 }}
          </span>
          <span class="ai-marquee-announcement-separator-{{ ai_gen_id }}">
            {{ block.settings.separator }}
          </span>
        {% endif %}

        {% if block.settings.announcement_text_5 != blank %}
          <span class="ai-marquee-announcement-item-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_5 }}
          </span>
          <span class="ai-marquee-announcement-separator-{{ ai_gen_id }}">
            {{ block.settings.separator }}
          </span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marquee announcement",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "announcement_text_1",
      "label": "Announcement 1",
      "default": "FREE SHIPPING ON ORDERS OVER ₹5000"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Announcement 2",
      "default": "NEW ARRIVALS EVERY FRIDAY"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Announcement 3",
      "default": "MEMBERS GET EARLY ACCESS"
    },
    {
      "type": "text",
      "id": "announcement_text_4",
      "label": "Announcement 4"
    },
    {
      "type": "text",
      "id": "announcement_text_5",
      "label": "Announcement 5"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "·"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#d4af37"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#d4af37"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size mobile",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Lower = faster"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "separator_spacing",
      "label": "Separator spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Marquee announcement"
    }
  ]
}
{% endschema %}