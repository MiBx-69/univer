{% doc %}
  @prompt
    Create a modern, premium, luxurious cart drawer for a high-end fashion/streetwear brand. The drawer should slide in from the right with a smooth animation, featuring: a dark or off-white minimalist background with generous whitespace, clean sans-serif typography, a sticky header with "Your Cart" title and item count badge, product line items with thumbnail images (rounded or square), product name, variant info, quantity stepper with minimal +/- controls, and line price. Include a subtotal section with a clean divider, a prominent full-width checkout button in black with white text, a secondary "Continue Shopping" link, and optional free shipping progress bar. The overall aesthetic should feel editorial and luxury — think clean lines, subtle borders, no clutter, refined hover states, and smooth transitions throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-cart-drawer-{{ ai_gen_id }} {
    display: block;
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    max-width: 480px;
    height: 100vh;
    background-color: {{ block.settings.drawer_background }};
    z-index: 9999;
    transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  }

  .ai-luxury-cart-drawer-{{ ai_gen_id }}.active {
    right: 0;
  }

  .ai-luxury-cart-drawer-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .ai-luxury-cart-drawer-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-luxury-cart-drawer-header-{{ ai_gen_id }} {
    position: sticky;
    top: 0;
    background-color: {{ block.settings.drawer_background }};
    padding: {{ block.settings.header_padding }}px {{ block.settings.side_padding }}px;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 10;
  }

  .ai-luxury-cart-drawer-title-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-luxury-cart-drawer-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-luxury-cart-drawer-count-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: {{ block.settings.badge_radius }}px;
    min-width: 24px;
    text-align: center;
  }

  .ai-luxury-cart-drawer-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
    transition: opacity 0.2s ease;
  }

  .ai-luxury-cart-drawer-close-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-luxury-cart-drawer-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
  }

  .ai-luxury-cart-drawer-body-{{ ai_gen_id }} {
    height: calc(100vh - 80px);
    overflow-y: auto;
    padding: {{ block.settings.content_padding }}px {{ block.settings.side_padding }}px;
  }

  .ai-luxury-cart-drawer-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-luxury-cart-drawer-empty-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0 0 24px;
    opacity: 0.7;
  }

  .ai-luxury-cart-drawer-items-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-luxury-cart-item-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    padding: 24px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-luxury-cart-item-{{ ai_gen_id }}:first-child {
    padding-top: 0;
  }

  .ai-luxury-cart-item-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.image_background }};
  }

  .ai-luxury-cart-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-luxury-cart-item-details-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-luxury-cart-item-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_name_size }}px;
    font-weight: {{ block.settings.product_name_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-luxury-cart-item-variant-{{ ai_gen_id }} {
    font-size: {{ block.settings.variant_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin: 0;
  }

  .ai-luxury-cart-item-footer-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .ai-luxury-cart-item-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid {{ block.settings.divider_color }};
    border-radius: {{ block.settings.quantity_radius }}px;
    padding: 6px 12px;
  }

  .ai-luxury-cart-item-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ block.settings.text_color }};
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-luxury-cart-item-quantity-btn-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-luxury-cart-item-quantity-btn-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
  }

  .ai-luxury-cart-item-quantity-value-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    min-width: 20px;
    text-align: center;
  }

  .ai-luxury-cart-item-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.text_color }};
  }

  .ai-luxury-cart-item-remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    transition: opacity 0.2s ease;
    margin-left: 8px;
  }

  .ai-luxury-cart-item-remove-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-luxury-cart-item-remove-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
  }

  .ai-luxury-cart-shipping-{{ ai_gen_id }} {
    margin-bottom: 24px;
    padding: 20px;
    background-color: {{ block.settings.shipping_background }};
    border-radius: {{ block.settings.shipping_radius }}px;
  }

  .ai-luxury-cart-shipping-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-luxury-cart-shipping-bar-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.shipping_bar_height }}px;
    background-color: {{ block.settings.shipping_bar_background }};
    border-radius: {{ block.settings.shipping_bar_radius }}px;
    overflow: hidden;
  }

  .ai-luxury-cart-shipping-progress-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.shipping_bar_fill }};
    transition: width 0.3s ease;
  }

  .ai-luxury-cart-subtotal-{{ ai_gen_id }} {
    padding: 24px 0;
    border-top: 1px solid {{ block.settings.divider_color }};
    margin-bottom: 24px;
  }

  .ai-luxury-cart-subtotal-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .ai-luxury-cart-subtotal-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtotal_label_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.subtotal_label_weight }};
  }

  .ai-luxury-cart-subtotal-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtotal_value_size }}px;
    font-weight: {{ block.settings.subtotal_value_weight }};
    color: {{ block.settings.text_color }};
  }

  .ai-luxury-cart-note-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin: 12px 0 0;
  }

  .ai-luxury-cart-checkout-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.checkout_padding }}px;
    background-color: {{ block.settings.checkout_background }};
    color: {{ block.settings.checkout_text_color }};
    border: none;
    border-radius: {{ block.settings.checkout_radius }}px;
    font-size: {{ block.settings.checkout_size }}px;
    font-weight: {{ block.settings.checkout_weight }};
    text-transform: {{ block.settings.checkout_transform }};
    letter-spacing: {{ block.settings.checkout_letter_spacing }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 16px;
  }

  .ai-luxury-cart-checkout-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.checkout_hover_background }};
    transform: translateY(-1px);
  }

  .ai-luxury-cart-continue-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px;
    background: none;
    border: none;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    cursor: pointer;
    text-decoration: underline;
    transition: opacity 0.2s ease;
  }

  .ai-luxury-cart-continue-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-cart-drawer-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-luxury-cart-drawer-header-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-luxury-cart-drawer-body-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-luxury-cart-item-image-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }
  }
{% endstyle %}

<luxury-cart-drawer-{{ ai_gen_id }}
  class="ai-luxury-cart-drawer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-free-shipping-threshold="{{ block.settings.free_shipping_threshold }}"
>
  <div class="ai-luxury-cart-drawer-header-{{ ai_gen_id }}">
    <div class="ai-luxury-cart-drawer-title-wrapper-{{ ai_gen_id }}">
      <h2 class="ai-luxury-cart-drawer-title-{{ ai_gen_id }}">{{ block.settings.drawer_title }}</h2>
      <span class="ai-luxury-cart-drawer-count-{{ ai_gen_id }}" data-cart-count>0</span>
    </div>
    <button
      class="ai-luxury-cart-drawer-close-{{ ai_gen_id }}"
      aria-label="Close cart"
      data-close-drawer
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="ai-luxury-cart-drawer-body-{{ ai_gen_id }}">
    <div class="ai-luxury-cart-drawer-empty-{{ ai_gen_id }}" data-empty-state>
      <p>{{ block.settings.empty_message }}</p>
      <button class="ai-luxury-cart-continue-{{ ai_gen_id }}" data-close-drawer>
        {{ block.settings.continue_shopping_text }}
      </button>
    </div>

    <div data-cart-content style="display: none;">
      {% if block.settings.show_shipping_bar %}
        <div class="ai-luxury-cart-shipping-{{ ai_gen_id }}" data-shipping-bar>
          <p class="ai-luxury-cart-shipping-text-{{ ai_gen_id }}" data-shipping-message></p>
          <div class="ai-luxury-cart-shipping-bar-{{ ai_gen_id }}">
            <div class="ai-luxury-cart-shipping-progress-{{ ai_gen_id }}" data-shipping-progress></div>
          </div>
        </div>
      {% endif %}

      <div class="ai-luxury-cart-drawer-items-{{ ai_gen_id }}" data-cart-items></div>

      <div class="ai-luxury-cart-subtotal-{{ ai_gen_id }}">
        <div class="ai-luxury-cart-subtotal-row-{{ ai_gen_id }}">
          <span class="ai-luxury-cart-subtotal-label-{{ ai_gen_id }}">{{ block.settings.subtotal_label }}</span>
          <span class="ai-luxury-cart-subtotal-value-{{ ai_gen_id }}" data-cart-subtotal></span>
        </div>
        <p class="ai-luxury-cart-note-{{ ai_gen_id }}">{{ block.settings.subtotal_note }}</p>
      </div>

      <button class="ai-luxury-cart-checkout-{{ ai_gen_id }}" data-checkout-button>
        {{ block.settings.checkout_button_text }}
      </button>

      <button class="ai-luxury-cart-continue-{{ ai_gen_id }}" data-close-drawer>
        {{ block.settings.continue_shopping_text }}
      </button>
    </div>
  </div>
</luxury-cart-drawer-{{ ai_gen_id }}>

<div class="ai-luxury-cart-drawer-overlay-{{ ai_gen_id }}" data-overlay></div>

<script>
  (function() {
    class LuxuryCartDrawer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.drawer = this;
        this.overlay = document.querySelector('[data-overlay]');
        this.closeButtons = document.querySelectorAll('[data-close-drawer]');
        this.checkoutButton = this.querySelector('[data-checkout-button]');
        this.freeShippingThreshold = parseFloat(this.dataset.freeShippingThreshold) * 100;
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateCart();
        
        document.addEventListener('cart:updated', () => {
          this.updateCart();
        });
      }

      setupEventListeners() {
        this.closeButtons.forEach(button => {
          button.addEventListener('click', () => this.close());
        });

        this.overlay.addEventListener('click', () => this.close());

        this.checkoutButton.addEventListener('click', () => {
          window.location.href = '/checkout';
        });

        document.addEventListener('click', (e) => {
          if (e.target.closest('[href="/cart"]') || e.target.closest('.cart-icon')) {
            e.preventDefault();
            this.open();
          }
        });
      }

      open() {
        this.drawer.classList.add('active');
        this.overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      close() {
        this.drawer.classList.remove('active');
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      async updateCart() {
        try {
          const response = await fetch('/cart.js');
          const cart = await response.json();
          this.renderCart(cart);
        } catch (error) {
          console.error('Error fetching cart:', error);
        }
      }

      renderCart(cart) {
        const countElement = this.querySelector('[data-cart-count]');
        const emptyState = this.querySelector('[data-empty-state]');
        const cartContent = this.querySelector('[data-cart-content]');
        const itemsContainer = this.querySelector('[data-cart-items]');
        const subtotalElement = this.querySelector('[data-cart-subtotal]');

        countElement.textContent = cart.item_count;

        if (cart.item_count === 0) {
          emptyState.style.display = 'block';
          cartContent.style.display = 'none';
          return;
        }

        emptyState.style.display = 'none';
        cartContent.style.display = 'block';

        itemsContainer.innerHTML = cart.items.map(item => this.renderCartItem(item)).join('');

        if (subtotalElement) {
          subtotalElement.textContent = this.formatMoney(cart.total_price);
        }

        this.updateShippingBar(cart.total_price);
        this.attachItemEventListeners();
      }

      renderCartItem(item) {
        const variantOptions = item.options_with_values
          .filter(option => option.value !== 'Default Title')
          .map(option => `${option.name}: ${option.value}`)
          .join(' / ');

        return `
          <div class="ai-luxury-cart-item-{{ ai_gen_id }}">
            <div class="ai-luxury-cart-item-image-{{ ai_gen_id }}">
              <img src="${item.featured_image.url}" alt="${item.product_title}" loading="lazy">
            </div>
            <div class="ai-luxury-cart-item-details-{{ ai_gen_id }}">
              <h3 class="ai-luxury-cart-item-name-{{ ai_gen_id }}">${item.product_title}</h3>
              ${variantOptions ? `<p class="ai-luxury-cart-item-variant-{{ ai_gen_id }}">${variantOptions}</p>` : ''}
              <div class="ai-luxury-cart-item-footer-{{ ai_gen_id }}">
                <div class="ai-luxury-cart-item-quantity-{{ ai_gen_id }}">
                  <button class="ai-luxury-cart-item-quantity-btn-{{ ai_gen_id }}" data-decrease data-key="${item.key}">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                    </svg>
                  </button>
                  <span class="ai-luxury-cart-item-quantity-value-{{ ai_gen_id }}">${item.quantity}</span>
                  <button class="ai-luxury-cart-item-quantity-btn-{{ ai_gen_id }}" data-increase data-key="${item.key}">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m7-7H5" />
                    </svg>
                  </button>
                </div>
                <span class="ai-luxury-cart-item-price-{{ ai_gen_id }}">${this.formatMoney(item.final_line_price)}</span>
                <button class="ai-luxury-cart-item-remove-{{ ai_gen_id }}" data-remove data-key="${item.key}">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        `;
      }

      attachItemEventListeners() {
        this.querySelectorAll('[data-increase]').forEach(button => {
          button.addEventListener('click', (e) => {
            const key = e.currentTarget.dataset.key;
            this.updateQuantity(key, 1);
          });
        });

        this.querySelectorAll('[data-decrease]').forEach(button => {
          button.addEventListener('click', (e) => {
            const key = e.currentTarget.dataset.key;
            this.updateQuantity(key, -1);
          });
        });

        this.querySelectorAll('[data-remove]').forEach(button => {
          button.addEventListener('click', (e) => {
            const key = e.currentTarget.dataset.key;
            this.removeItem(key);
          });
        });
      }

      async updateQuantity(key, change) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: key, quantity: change })
          });
          const cart = await response.json();
          this.renderCart(cart);
        } catch (error) {
          console.error('Error updating quantity:', error);
        }
      }

      async removeItem(key) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: key, quantity: 0 })
          });
          const cart = await response.json();
          this.renderCart(cart);
        } catch (error) {
          console.error('Error removing item:', error);
        }
      }

      updateShippingBar(totalPrice) {
        const shippingBar = this.querySelector('[data-shipping-bar]');
        if (!shippingBar) return;

        const messageElement = this.querySelector('[data-shipping-message]');
        const progressElement = this.querySelector('[data-shipping-progress]');
        
        const remaining = this.freeShippingThreshold - totalPrice;
        const percentage = Math.min((totalPrice / this.freeShippingThreshold) * 100, 100);

        if (remaining > 0) {
          messageElement.textContent = `{{ block.settings.shipping_message_incomplete }} ${this.formatMoney(remaining)} {{ block.settings.shipping_message_suffix }}`;
        } else {
          messageElement.textContent = '{{ block.settings.shipping_message_complete }}';
        }

        progressElement.style.width = `${percentage}%`;
      }

      formatMoney(cents) {
        const amount = (cents / 100).toFixed(2);
        return `{{ cart.currency.symbol }}${amount}`;
      }
    }

    customElements.define('luxury-cart-drawer-{{ ai_gen_id }}', LuxuryCartDrawer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Luxury cart drawer",
  "settings": [
    {
      "type": "header",
      "content": "Drawer settings"
    },
    {
      "type": "text",
      "id": "drawer_title",
      "label": "Title",
      "default": "Your Cart"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "drawer_background",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#E6E6E6"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Title case",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
